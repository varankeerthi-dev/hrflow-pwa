rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Basic helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function getAuthUser() {
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(userPath) ? get(userPath).data : null;
    }

    function isRole(userData, roleName) {
      return userData != null && "role" in userData && userData.role != null && userData.role.lower() == roleName.lower();
    }

    function isManagement(userData) {
      return userData != null && "role" in userData && userData.role != null && 
             (userData.role.lower() == 'admin' || userData.role.lower() == 'hr' || userData.role.lower() == 'md');
    }
    
    // Users collection
    match /users/{uid} {
      allow read: if isSignedIn() && (
        request.auth.uid == uid || 
        (isManagement(getAuthUser()) && getAuthUser().orgId == resource.data.orgId)
      );
      allow list: if isSignedIn() && isManagement(getAuthUser());
      allow create: if isSignedIn() && request.auth.uid == uid;
      allow update: if isSignedIn() && (
        request.auth.uid == uid || 
        (isRole(getAuthUser(), 'admin') && getAuthUser().orgId == resource.data.orgId)
      );
      allow delete: if isSignedIn() && isRole(getAuthUser(), 'admin') && getAuthUser().orgId == resource.data.orgId;
    }
    
    // Organisations collection
    match /organisations/{orgId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && getAuthUser().orgId == orgId;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && isRole(getAuthUser(), 'admin') && getAuthUser().orgId == orgId;
      
      // Generic rule for sub-collections
      match /{collection}/{docId} {
        allow read: if isSignedIn() && getAuthUser().orgId == orgId;
        allow write: if isSignedIn() && isManagement(getAuthUser()) && getAuthUser().orgId == orgId;
      }

      // Specific overrides
      
      // Requests (Leaves, Permissions, Advances, etc.)
      match /requests/{id} {
        allow read, create: if isSignedIn() && getAuthUser().orgId == orgId;
        allow update, delete: if isSignedIn() && isManagement(getAuthUser()) && getAuthUser().orgId == orgId;
      }

      // Attendance: Org members can read/write their own and others (for team view)
      match /attendance/{attId} {
        allow read, write: if isSignedIn() && getAuthUser().orgId == orgId;
        allow delete: if isSignedIn() && isManagement(getAuthUser()) && getAuthUser().orgId == orgId;
      }
      
      // Legacy overrides
      match /corrections/{id} { allow create: if isSignedIn() && getAuthUser().orgId == orgId; }
      match /otRequests/{id} { allow create: if isSignedIn() && getAuthUser().orgId == orgId; }
      match /otApprovals/{id} { allow read, create: if isSignedIn() && getAuthUser().orgId == orgId; }
      match /advances/{id} { allow create: if isSignedIn() && getAuthUser().orgId == orgId; }
      match /leaves/{id} { allow create: if isSignedIn() && getAuthUser().orgId == orgId; }
      match /fines/{id} { allow create: if isSignedIn() && getAuthUser().orgId == orgId; }
      match /activityLogs/{id} { allow read, create: if isSignedIn() && getAuthUser().orgId == orgId; }
      match /logs/{id} { allow read, create: if isSignedIn() && getAuthUser().orgId == orgId; }
      match /jobs/{id} { allow read: if isSignedIn() && getAuthUser().orgId == orgId; }
      match /applicants/{id} { allow read, create: if isSignedIn() && getAuthUser().orgId == orgId; }
      match /documents/{id} { allow read: if isSignedIn() && getAuthUser().orgId == orgId; }
      
      // Tasks
      match /tasks/{taskId} {
        allow read: if isSignedIn() && getAuthUser().orgId == orgId && (
          resource == null || !resource.data.isPersonal || resource.data.createdBy == request.auth.uid
        );
        allow create: if isSignedIn() && getAuthUser().orgId == orgId && request.resource.data.orgId == orgId;
        allow update: if isSignedIn() && getAuthUser().orgId == orgId && (
          !resource.data.isPersonal || resource.data.createdBy == request.auth.uid
        );
        allow delete: if isSignedIn() && getAuthUser().orgId == orgId && (
          !resource.data.isPersonal || resource.data.createdBy == request.auth.uid
        );
      }

      // Team Chat
      match /chats/{chatId} {
        allow read: if isSignedIn() && getAuthUser().orgId == orgId && request.auth.uid in resource.data.participantIds;
        allow create: if isSignedIn() && getAuthUser().orgId == orgId && request.auth.uid in request.resource.data.participantIds;
        allow update: if isSignedIn() && getAuthUser().orgId == orgId && request.auth.uid in resource.data.participantIds;
        
        match /messages/{messageId} {
          allow read: if isSignedIn() && getAuthUser().orgId == orgId && request.auth.uid in get(/databases/$(database)/documents/organisations/$(orgId)/chats/$(chatId)).data.participantIds;
          allow create: if isSignedIn() && getAuthUser().orgId == orgId && request.auth.uid in get(/databases/$(database)/documents/organisations/$(orgId)/chats/$(chatId)).data.participantIds;
        }
      }
    }
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
