rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isAdmin() {
      return isSignedIn() && getUserData().role.lower() == 'admin';
    }

    match /organisations/{orgId} {
      allow read: if true;
      allow write: if isAdmin();

      // Explicit rules for core sub-collections
      match /employees/{employeeId} {
        allow read, write: if true;
      }
      
      match /attendance/{attendanceId} {
        allow read, write: if true;
      }

      match /activityLogs/{logId} {
        allow read, write: if true;
      }
      
      match /shifts/{shiftId} {
        allow read, write: if true;
      }
      
      match /roles/{roleId} {
        allow read, write: if true;
      }
      
      match /minWorkHours/{mwhId} {
        allow read, write: if true;
      }
      
      match /approvalSettings/{settingId} {
        allow read, write: if true;
      }
      
      match /requests/{requestId} {
        allow read, write: if isSignedIn();
      }

      match /advances_expenses/{requestId} {
        allow read, write: if isSignedIn();
      }
      
      match /logs/{logId} {
        allow read, write: if true;
      }
    }

    match /users/{userId} {
      allow read: if true;
      allow write: if isSignedIn() && (isAdmin() || request.auth.uid == userId);
    }

    // Catch-all for other sub-collections or top-level docs
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
