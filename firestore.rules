rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isAdmin() {
      return isSignedIn() && getUserData().role.lower() == 'admin';
    }

    match /organisations/{orgId} {
      allow read: if true;
      allow write: if isAdmin();

      match /employees/{employeeId} {
        allow read, write: if true; // Keeping existing open rules for employees subcollection
      }
      
      match /shifts/{shiftId} {
        allow read, write: if true;
      }
      
      match /roles/{roleId} {
        allow read, write: if true;
      }
      
      match /minWorkHours/{mwhId} {
        allow read, write: if true;
      }
      
      match /approvalSettings/{settingId} {
        allow read, write: if true;
      }
      
      match /logs/{logId} {
        allow read, write: if true;
      }
    }

    match /users/{userId} {
      allow read: if true;
      allow write: if isSignedIn() && (
        // Allow if user is admin OR updating their own document
        (isAdmin() || request.auth.uid == userId) &&
        
        // Rule: Organisation creator cannot change role from admin unless another admin exists
        (
          let org = get(/databases/$(database)/documents/organisations/$(request.resource.data.orgId)).data;
          let isCreator = org.creatorId == userId;
          let changingFromAdmin = resource.data.role.lower() == 'admin' && request.resource.data.role.lower() != 'admin';
          
          isCreator && changingFromAdmin ? org.adminUids.size() > 1 : true
        )
      );
    }

    match /{document=**} {
      allow read, write: if true;
    }
  }
}
