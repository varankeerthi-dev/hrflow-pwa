rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if a user is an employee of an organisation
    function isEmployee(orgId) {
      return request.auth != null && exists(/databases/$(database)/documents/organisations/$(orgId)/employees/$(request.auth.uid));
    }

    // Rules for users collection
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Rules for organisations collection
    match /organisations/{orgId} {
      // Allow creation of a new organisation if authenticated
      allow create: if request.auth != null;
      
      // Allow read of organisation details if they are an employee
      // Also allow read for any authenticated user so they can join/verify org existence
      allow read: if request.auth != null;

      // Allow write (update/delete) for employees of this organisation
      // Note: In a real system, you might want to restrict this further to admins
      allow update, delete: if isEmployee(orgId);

      // Rules for all sub-collections within an organisation
      match /{allSubCollections=**} {
        allow read, write: if isEmployee(orgId);
      }
    }
  }
}
