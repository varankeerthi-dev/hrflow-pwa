rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ─── Helper Functions ─────────────────────────────────────────────────────
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function getRoleData(orgId, roleName) {
      // Note: This assumes roles are stored in /organisations/{orgId}/roles/{roleId} 
      // and we need to find the one where data.name == roleName.
      // Firestore rules don't support collection group queries or filtering well inside 'get'.
      // Better approach: Check if user is admin OR check specific module right.
      return getUserData().role;
    }

    function isAdmin() {
      return request.auth != null && getUserData().role == 'admin';
    }

    // New Dynamic Permission Check
    // Checks if the user's role has 'full' or a specific right for a module
    function hasModuleRight(orgId, module, right) {
      let user = getUserData();
      if (user.role == 'admin') return true;
      
      // Since we can't easily iterate collections in rules to find a role by name,
      // and permissions are usually cached in the user doc for performance:
      return user.permissions[module][right] == true || user.permissions[module].full == true;
    }

    function isOrgMember(orgId) {
      return request.auth != null && getUserData().orgId == orgId;
    }

    // ─── Collection Rules ─────────────────────────────────────────────────────

    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    
    match /organisations/{orgId} {
      allow get: if request.auth != null;
      allow list: if isOrgMember(orgId);
      allow write: if isAdmin() || (request.auth != null && getUserData().orgId == null);
      
      // Dynamic Modules
      match /attendance/{attId} {
        allow read: if isOrgMember(orgId) && hasModuleRight(orgId, 'Attendance', 'view');
        allow create: if isOrgMember(orgId) && hasModuleRight(orgId, 'Attendance', 'create');
        allow update: if isOrgMember(orgId) && hasModuleRight(orgId, 'Attendance', 'edit');
        allow delete: if isOrgMember(orgId) && hasModuleRight(orgId, 'Attendance', 'delete');
      }

      match /employees/{empId} {
        allow read: if isOrgMember(orgId) && (hasModuleRight(orgId, 'Employees', 'view') || request.auth.uid == empId);
        allow write: if isOrgMember(orgId) && hasModuleRight(orgId, 'Employees', 'create');
        allow update: if isOrgMember(orgId) && hasModuleRight(orgId, 'Employees', 'edit');
        allow delete: if isOrgMember(orgId) && hasModuleRight(orgId, 'Employees', 'delete');
      }

      match /shifts/{shiftId} {
        allow read: if isOrgMember(orgId);
        allow write: if isOrgMember(orgId) && hasModuleRight(orgId, 'ShiftPlanning', 'full');
      }

      match /corrections/{corrId} {
        allow read: if isOrgMember(orgId);
        allow create: if isOrgMember(orgId); 
        allow update: if isOrgMember(orgId) && hasModuleRight(orgId, 'Correction', 'edit');
        allow delete: if isOrgMember(orgId) && hasModuleRight(orgId, 'Correction', 'delete');
      }

      match /leaves/{leaveId} {
        allow read: if isOrgMember(orgId);
        allow create: if isOrgMember(orgId);
        allow update: if isOrgMember(orgId) && hasModuleRight(orgId, 'Leave', 'edit');
      }

      match /salarySlips/{slipId} {
        allow read: if isOrgMember(orgId) && (hasModuleRight(orgId, 'SalarySlip', 'view') || resource.data.employeeId == request.auth.uid);
        allow write: if isOrgMember(orgId) && hasModuleRight(orgId, 'SalarySlip', 'create');
      }

      match /jobs/{jobId} {
        allow read: if isOrgMember(orgId);
        allow write: if isOrgMember(orgId) && hasModuleRight(orgId, 'Recruitment', 'create');
      }

      match /applicants/{appId} {
        allow read: if isOrgMember(orgId);
        allow write: if isOrgMember(orgId) && hasModuleRight(orgId, 'Recruitment', 'edit');
      }

      match /documents/{docId} {
        allow read: if isOrgMember(orgId);
        allow write: if isOrgMember(orgId) && hasModuleRight(orgId, 'DocumentManagement', 'create');
      }

      match /requests/{reqId} {
        allow read: if isOrgMember(orgId);
        allow create: if isOrgMember(orgId);
        allow update: if isOrgMember(orgId) && (hasModuleRight(orgId, 'Approvals', 'approve') || resource.data.employeeId == request.auth.uid);
      }

      // Allow reading roles for login/permission check
      match /roles/{roleId} {
        allow read: if isOrgMember(orgId);
        allow write: if isAdmin();
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
