rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Basic org membership check
    function isOrgMember(orgId) {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.orgId == orgId;
    }

    // Users can read/write their own user document
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // All documents under an organisation are accessible to members of that org
    match /organisations/{orgId}/{document=**} {
      allow read, write: if isOrgMember(orgId);
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
