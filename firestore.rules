rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Check if user is signed in
    function isSignedIn() {
      return request.auth != null;
    }

    // Get current user document directly from path to avoid multiple get() calls
    function getAuthUser() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Role check helper
    function hasRole(userData, roleName) {
      return userData != null && "role" in userData && userData.role != null && userData.role.lower() == roleName.lower();
    }

    // Management check helper (admin, hr, md)
    function isManagement(userData) {
      return userData != null && "role" in userData && userData.role != null && 
             (userData.role.lower() == 'admin' || userData.role.lower() == 'hr' || userData.role.lower() == 'md');
    }
    
    // USERS COLLECTION
    match /users/{uid} {
      // Users can read their own doc.
      // Management can read any user doc in their org.
      allow read: if isSignedIn() && (
        request.auth.uid == uid || 
        (isManagement(getAuthUser()) && getAuthUser().orgId == resource.data.orgId)
      );
      
      // Management can list users.
      allow list: if isSignedIn() && isManagement(getAuthUser());
      
      // Users can create their own doc during registration.
      allow create: if isSignedIn() && request.auth.uid == uid;
      
      // Users can update their own doc.
      // Admin can update any user doc in their org.
      allow update: if isSignedIn() && (
        request.auth.uid == uid || 
        (hasRole(getAuthUser(), 'admin') && getAuthUser().orgId == (resource != null ? resource.data.orgId : request.resource.data.orgId))
      );
      
      // Admin can delete users in their org.
      allow delete: if isSignedIn() && hasRole(getAuthUser(), 'admin') && getAuthUser().orgId == resource.data.orgId;
    }
    
    // ORGANISATIONS COLLECTION
    match /organisations/{orgId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && getAuthUser().orgId == orgId;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && hasRole(getAuthUser(), 'admin') && getAuthUser().orgId == orgId;
      
      // Generic rule for sub-collections (employees, shifts, etc.)
      match /{collection}/{docId} {
        allow read: if isSignedIn() && getAuthUser().orgId == orgId;
        allow write: if isSignedIn() && isManagement(getAuthUser()) && getAuthUser().orgId == orgId;
      }

      // Specific overrides for requests (Leaves, Advances, etc.)
      match /requests/{id} {
        allow read, create: if isSignedIn() && getAuthUser().orgId == orgId;
        allow update, delete: if isSignedIn() && isManagement(getAuthUser()) && getAuthUser().orgId == orgId;
      }

      // Specific overrides for attendance
      match /attendance/{attId} {
        allow read, write: if isSignedIn() && getAuthUser().orgId == orgId;
        allow delete: if isSignedIn() && isManagement(getAuthUser()) && getAuthUser().orgId == orgId;
      }
      
      // Ensure specific permissions for sensitive collections
      match /employees/{empId} {
        allow read: if isSignedIn() && getAuthUser().orgId == orgId;
        allow write: if isSignedIn() && isManagement(getAuthUser()) && getAuthUser().orgId == orgId;
      }
    }
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
