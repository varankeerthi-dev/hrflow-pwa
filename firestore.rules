rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Basic org membership check
    function isOrgMember(orgId) {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return request.auth != null && 
             userDoc != null && 
             userDoc.data.get('orgId', null) == orgId;
    }

    // Users can read/write their own user document
    match /users/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Organisations creation and access
    match /organisations/{orgId} {
      // Allow any authenticated user to create a new organization
      allow create: if request.auth != null;
      
      // Allow any authenticated user to GET a specific organization document 
      // (Required for validation during joining with a code)
      // Restricted to 'get' to prevent listing all organizations
      allow get: if request.auth != null;
      
      // Members can update or list (search)
      allow update, delete, list: if isOrgMember(orgId);
      
      // All documents under an organisation are accessible to members of that org
      match /{allChildren=**} {
        allow read, write: if isOrgMember(orgId);
      }
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
