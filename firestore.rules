rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Basic helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function getAuthUser() {
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(userPath) ? get(userPath).data : null;
    }

    // Helper to check if UID is a permanent admin of the org
    function isOrgAdmin(orgId) {
      let orgPath = /databases/$(database)/documents/organisations/$(orgId);
      return exists(orgPath) && request.auth.uid in get(orgPath).data.adminUids;
    }

    function isRole(userData, roleName) {
      return userData != null && "role" in userData && userData.role != null && userData.role.lower() == roleName.lower();
    }

    function isManagement(userData, orgId) {
      // Check role in user doc OR check if they are in adminUids of the org
      return (userData != null && "role" in userData && userData.role != null && 
             (userData.role.lower() == 'admin' || userData.role.lower() == 'hr' || userData.role.lower() == 'md')) ||
             isOrgAdmin(orgId);
    }
    
    // USERS COLLECTION
    match /users/{uid} {
      allow read: if isSignedIn() && (
        request.auth.uid == uid || 
        (isSignedIn() && isManagement(getAuthUser(), getAuthUser().orgId))
      );
      allow list: if isSignedIn() && isManagement(getAuthUser(), getAuthUser().orgId);
      allow create: if isSignedIn() && request.auth.uid == uid;
      allow update: if isSignedIn() && (
        request.auth.uid == uid || 
        (isSignedIn() && isOrgAdmin(getAuthUser().orgId)) ||
        (isRole(getAuthUser(), 'admin') && getAuthUser().orgId == (resource != null ? resource.data.orgId : request.resource.data.orgId))
      );
      allow delete: if isSignedIn() && (isRole(getAuthUser(), 'admin') || isOrgAdmin(getAuthUser().orgId)) && getAuthUser().orgId == resource.data.orgId;
    }
    
    // ORGANISATIONS COLLECTION
    match /organisations/{orgId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && getAuthUser().orgId == orgId;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (isRole(getAuthUser(), 'admin') || isOrgAdmin(orgId)) && getAuthUser().orgId == orgId;
      
      // Generic rule for sub-collections
      match /{collection}/{docId} {
        allow read: if isSignedIn() && getAuthUser().orgId == orgId;
        allow write: if isSignedIn() && isManagement(getAuthUser(), orgId) && getAuthUser().orgId == orgId;
      }

      // Specific overrides
      match /requests/{id} {
        allow read, create: if isSignedIn() && getAuthUser().orgId == orgId;
        allow update, delete: if isSignedIn() && isManagement(getAuthUser(), orgId) && getAuthUser().orgId == orgId;
      }

      match /attendance/{attId} {
        allow read, write: if isSignedIn() && getAuthUser().orgId == orgId;
        allow delete: if isSignedIn() && isManagement(getAuthUser(), orgId) && getAuthUser().orgId == orgId;
      }
      
      match /employees/{empId} {
        allow read: if isSignedIn() && getAuthUser().orgId == orgId;
        allow write: if isSignedIn() && isManagement(getAuthUser(), orgId) && getAuthUser().orgId == orgId;
      }
    }
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
