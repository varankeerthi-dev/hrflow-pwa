rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Explicitly keep employee/profile/status-log paths open for the current app setup.
    match /organisations/{orgId} {
      match /employees/{employeeId} {
        allow read, write: if true;
      }

      match /logs/{logId} {
        allow read, write: if true;
      }

      match /{document=**} {
        allow read, write: if true;
      }
    }

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      // Also allow admins of the same org to read/write user docs for management
      allow read, write: if true; // Keeping it open for now as per your current open rules
    }

    match /{document=**} {
      allow read, write: if true;
    }
  }
}
