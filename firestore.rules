rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Shared helpers using user document instead of token claims
    function userDoc() {
      return request.auth != null ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data : null;
    }
    function userOrg() {
      let u = userDoc();
      return u != null ? u.orgId : null;
    }
    function isAdmin() {
      let u = userDoc();
      let r = u != null && u.role != null ? u.role : '';
      return r == 'admin' || r == 'md' || r == 'Admin' || r == 'MD';
    }
    function sameOrg(data) {
      return request.auth != null && (
        data.organizationId == userOrg() ||
        (data.organizationId == null && (
          data.createdBy == request.auth.uid ||
          request.auth.uid in data.assignedTo
        ))
      );
    }
    function taskVisible(data) {
      let assigned = request.auth.uid in data.assignedTo;
      let creator = request.auth.uid == data.createdBy;
      return data.isPersonal ? (creator || assigned) : (assigned || isAdmin());
    }

    // Tasks
    match /tasks/{taskId} {
      allow read: if sameOrg(resource.data) && taskVisible(resource.data);
      allow create: if request.auth != null &&
        request.resource.data.organizationId == userOrg();
      allow update, delete: if sameOrg(resource.data) && (
        request.auth.uid in resource.data.assignedTo ||
        request.auth.uid == resource.data.createdBy ||
        isAdmin()
      );
      
      match /messages/{messageId} {
        allow read: if sameOrg(get(/databases/$(database)/documents/tasks/$(taskId)).data) &&
          taskVisible(get(/databases/$(database)/documents/tasks/$(taskId)).data);
        allow create: if sameOrg(get(/databases/$(database)/documents/tasks/$(taskId)).data) && (
          request.auth.uid in get(/databases/$(database)/documents/tasks/$(taskId)).data.assignedTo ||
          request.auth.uid == get(/databases/$(database)/documents/tasks/$(taskId)).data.createdBy
        );
      }
    }
    
    // Reminders
    match /reminders/{reminderId} {
      allow read: if request.auth != null &&
        resource.data.organizationId == userOrg() && (
          resource.data.type == "general" ||
          resource.data.targetUsers == null ||
          request.auth.uid in resource.data.targetUsers ||
          request.auth.uid == resource.data.createdBy
        );
      allow create: if request.auth != null &&
        request.resource.data.organizationId == userOrg();
      allow update: if request.auth != null;  // dismissing adds uid
      allow delete: if request.auth != null && 
                       resource.data.createdBy == request.auth.uid;
    }
    
    // Ideas (personal to creator)
    match /ideas/{ideaId} {
      allow read: if request.auth != null && resource.data.createdBy == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.createdBy == request.auth.uid;
    }
    
    // Existing rules retained for orgs/users
    function isEmployee(orgId) {
      return request.auth != null && exists(/databases/$(database)/documents/organisations/$(orgId)/employees/$(request.auth.uid));
    }

    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    match /organisations/{orgId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null;
      allow update, delete: if isEmployee(orgId);
      // Employees: allow read if same org (matches original behavior when user is part of org)
      match /employees/{empId} {
        allow read: if request.auth != null && (
          userOrg() == orgId || isEmployee(orgId) || isAdmin()
        );
        allow write: if isEmployee(orgId) || isAdmin();
      }
      // Other subcollections
      match /{allSubCollections=**} {
        allow read, write: if isEmployee(orgId);
      }
    }
  }
}
