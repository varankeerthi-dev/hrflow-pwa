rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ─── Helper Functions ─────────────────────────────────────────────────────
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      let userData = getUserData();
      return request.auth != null && (userData.role == 'admin' || userData.role == 'Admin');
    }

    function isOrgMember(orgId) {
      let userData = getUserData();
      return request.auth != null && userData.orgId == orgId;
    }

    // Safer Dynamic Permission Check
    function hasModuleRight(module, right) {
      let user = getUserData();
      if (user.role == 'admin' || user.role == 'Admin') return true;
      
      // Use get() with default value to avoid errors if permissions map is incomplete
      let perms = user.get('permissions', {});
      let modPerms = perms.get(module, {});
      return modPerms.get(right, false) == true || modPerms.get('full', false) == true;
    }

    // ─── User Rules ───────────────────────────────────────────────────────────

    match /users/{uid} {
      // Users can read/write their own data
      // Admins can read/write users in their own organization
      allow read: if request.auth != null && (
        request.auth.uid == uid || 
        (isAdmin() && getUserData().orgId == get(/databases/$(database)/documents/users/$(uid)).data.orgId)
      );
      allow write: if request.auth != null && (
        request.auth.uid == uid || 
        (isAdmin() && getUserData().orgId == get(/databases/$(database)/documents/users/$(uid)).data.orgId)
      );
    }
    
    // ─── Organization Rules ───────────────────────────────────────────────────

    match /organisations/{orgId} {
      allow get: if request.auth != null;
      allow list: if isOrgMember(orgId);
      allow write: if isAdmin() || (request.auth != null && !getUserData().keys().contains('orgId'));
      
      // Subcollections
      match /attendance/{attId} {
        allow read: if isOrgMember(orgId) && hasModuleRight('Attendance', 'view');
        allow create: if isOrgMember(orgId) && hasModuleRight('Attendance', 'create');
        allow update: if isOrgMember(orgId) && hasModuleRight('Attendance', 'edit');
        allow delete: if isOrgMember(orgId) && hasModuleRight('Attendance', 'delete');
      }

      match /employees/{empId} {
        allow read: if isOrgMember(orgId) && (hasModuleRight('Employees', 'view') || request.auth.uid == empId);
        allow create: if isOrgMember(orgId) && hasModuleRight('Employees', 'create');
        allow update: if isOrgMember(orgId) && hasModuleRight('Employees', 'edit');
        allow delete: if isOrgMember(orgId) && hasModuleRight('Employees', 'delete');
      }

      match /shifts/{shiftId} {
        allow read: if isOrgMember(orgId);
        allow write: if isOrgMember(orgId) && hasModuleRight('Shifts', 'full');
      }

      match /roles/{roleId} {
        allow read: if isOrgMember(orgId);
        allow write: if isOrgMember(orgId) && (isAdmin() || hasModuleRight('Roles', 'full'));
      }

      match /corrections/{corrId} {
        allow read: if isOrgMember(orgId);
        allow create: if isOrgMember(orgId); 
        allow update: if isOrgMember(orgId) && hasModuleRight('Correction', 'edit');
        allow delete: if isOrgMember(orgId) && hasModuleRight('Correction', 'delete');
      }

      match /leaves/{leaveId} {
        allow read: if isOrgMember(orgId);
        allow create: if isOrgMember(orgId);
        allow update: if isOrgMember(orgId) && hasModuleRight('Leave', 'edit');
      }

      match /salarySlips/{slipId} {
        allow read: if isOrgMember(orgId) && (hasModuleRight('SalarySlip', 'view') || resource.data.employeeId == request.auth.uid);
        allow write: if isOrgMember(orgId) && hasModuleRight('SalarySlip', 'create');
      }

      match /jobs/{jobId} {
        allow read: if isOrgMember(orgId);
        allow write: if isOrgMember(orgId) && hasModuleRight('Recruitment', 'create');
      }

      match /applicants/{appId} {
        allow read: if isOrgMember(orgId);
        allow write: if isOrgMember(orgId) && hasModuleRight('Recruitment', 'edit');
      }

      match /documents/{docId} {
        allow read: if isOrgMember(orgId);
        allow write: if isOrgMember(orgId) && hasModuleRight('DocumentManagement', 'create');
      }

      match /requests/{reqId} {
        allow read: if isOrgMember(orgId);
        allow create: if isOrgMember(orgId);
        allow update: if isOrgMember(orgId) && (hasModuleRight('Approvals', 'approve') || resource.data.employeeId == request.auth.uid);
      }

      match /logs/{logId} {
        allow read: if isOrgMember(orgId) && isAdmin();
        allow create: if isOrgMember(orgId);
      }
    }

    // Global Deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
