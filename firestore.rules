rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to get user's data
    function getUserData() {
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(userPath) ? get(userPath).data : null;
    }
    
    // Helper function to get user's orgId
    function getUserOrgId() {
      let data = getUserData();
      return request.auth != null && data != null ? data.orgId : null;
    }
    
    // Helper function to check if user is admin
    function isAdmin() {
      let data = getUserData();
      return request.auth != null && 
        data != null &&
        "role" in data && 
        data.role != null && 
        data.role.lower() == 'admin';
    }
    
    // Helper function to check if user is HR
    function isHR() {
      let data = getUserData();
      return request.auth != null && 
        data != null &&
        "role" in data && 
        data.role != null && 
        data.role.lower() == 'hr';
    }

    // Helper function to check if user is MD (Managing Director)
    function isMD() {
      let data = getUserData();
      return request.auth != null && 
        data != null &&
        "role" in data && 
        data.role != null && 
        data.role.lower() == 'md';
    }
    
    // Helper function to check if user is admin, HR or MD
    function isManagement() {
      return isAdmin() || isHR() || isMD();
    }
    
    // Helper function to check if user belongs to an org
    function isOrgMember() {
      return request.auth != null && getUserOrgId() != null;
    }
    
    // Users collection
    match /users/{uid} {
      allow read: if request.auth != null && (
        request.auth.uid == uid || 
        (isOrgMember() && (getUserOrgId() == resource.data.orgId || isAdmin()))
      );
      allow list: if isOrgMember() && (isAdmin() || request.query.limit <= 100);
      allow create: if request.auth != null && (
        request.auth.uid == uid || 
        (isAdmin() && getUserOrgId() == request.resource.data.orgId)
      );
      allow update: if request.auth != null && (
        request.auth.uid == uid || 
        (isAdmin() && getUserOrgId() == resource.data.orgId)
      );
      allow delete: if isAdmin() && isOrgMember() && getUserOrgId() == resource.data.orgId;
    }
    
    // Organisations collection
    match /organisations/{orgId} {
      allow get: if request.auth != null;
      allow list: if request.auth != null && getUserOrgId() == orgId;
      allow create: if request.auth != null && (getUserOrgId() == null || getUserOrgId() == orgId);
      allow update, delete: if isAdmin() && getUserOrgId() == orgId;
      
      // Generic rule for sub-collections: Org members can read, Management can write
      match /{collection}/{docId} {
        allow read: if isOrgMember() && getUserOrgId() == orgId;
        allow write: if isManagement() && getUserOrgId() == orgId;
      }

      // Specific overrides
      
      // Requests (Leaves, Permissions, Advances, etc.)
      match /requests/{id} {
        allow read, create: if isOrgMember() && getUserOrgId() == orgId;
        allow update, delete: if isManagement() && getUserOrgId() == orgId;
      }

      // Attendance: Org members can read/write their own and others (for team view)
      match /attendance/{attId} {
        allow read, write: if isOrgMember() && getUserOrgId() == orgId;
        allow delete: if isManagement() && getUserOrgId() == orgId;
      }
      
      // Corrections, OT Requests, Advances, Leaves, Fines: Org members can create
      // (Mostly migrated to /requests, but keeping these for backward compatibility)
      match /corrections/{id} { allow create: if isOrgMember() && getUserOrgId() == orgId; }
      match /otRequests/{id} { allow create: if isOrgMember() && getUserOrgId() == orgId; }
      match /otApprovals/{id} { allow read, create: if isOrgMember() && getUserOrgId() == orgId; }
      match /advances/{id} { allow create: if isOrgMember() && getUserOrgId() == orgId; }
      match /leaves/{id} { allow create: if isOrgMember() && getUserOrgId() == orgId; }
      match /fines/{id} { allow create: if isOrgMember() && getUserOrgId() == orgId; }
      
      // Activity Logs & Logs: Org members can read/create
      match /activityLogs/{id} { allow read, create: if isOrgMember() && getUserOrgId() == orgId; }
      match /logs/{id} { allow read, create: if isOrgMember() && getUserOrgId() == orgId; }
      
      // Recruitment (Jobs & Applicants)
      match /jobs/{id} { allow read: if isOrgMember() && getUserOrgId() == orgId; }
      match /applicants/{id} { allow read, create: if isOrgMember() && getUserOrgId() == orgId; }
      
      // Documents
      match /documents/{id} { allow read: if isOrgMember() && getUserOrgId() == orgId; }
      
      // Tasks
      match /tasks/{taskId} {
        allow read: if isOrgMember() && getUserOrgId() == orgId && (
          resource == null || !resource.data.isPersonal || resource.data.createdBy == request.auth.uid
        );
        allow create: if isOrgMember() && getUserOrgId() == orgId && request.resource.data.orgId == orgId;
        allow update: if isOrgMember() && getUserOrgId() == orgId && (
          !resource.data.isPersonal || resource.data.createdBy == request.auth.uid
        );
        allow delete: if isOrgMember() && getUserOrgId() == orgId && (
          !resource.data.isPersonal || resource.data.createdBy == request.auth.uid
        );
      }

      // Team Chat
      match /chats/{chatId} {
        allow read: if isOrgMember() && getUserOrgId() == orgId && request.auth.uid in resource.data.participantIds;
        allow create: if isOrgMember() && getUserOrgId() == orgId && request.auth.uid in request.resource.data.participantIds;
        allow update: if isOrgMember() && getUserOrgId() == orgId && request.auth.uid in resource.data.participantIds;
        
        match /messages/{messageId} {
          allow read: if isOrgMember() && getUserOrgId() == orgId && request.auth.uid in get(/databases/$(database)/documents/organisations/$(orgId)/chats/$(chatId)).data.participantIds;
          allow create: if isOrgMember() && getUserOrgId() == orgId && request.auth.uid in get(/databases/$(database)/documents/organisations/$(orgId)/chats/$(chatId)).data.participantIds;
        }
      }
    }
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
