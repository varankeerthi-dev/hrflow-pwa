rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to get user's orgId
    function getUserOrgId() {
      return request.auth != null ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.orgId : null;
    }
    
    // Helper function to check if user is admin
    function isAdmin() {
      return request.auth != null && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    // Helper function to check if user is HR
    function isHR() {
      return request.auth != null && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'HR';
    }
    
    // Helper function to check if user is admin or HR
    function isAdminOrHR() {
      return isAdmin() || isHR();
    }
    
    // Helper function to check if user is employee
    function isEmployee() {
      return request.auth != null && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['employee', 'Employee'];
    }
    
    // Users collection - read/write own document (or create if no orgId yet)
    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow create: if request.auth != null && request.auth.uid == uid;
      allow update: if request.auth != null && request.auth.uid == uid;
    }
    
    // Organisations collection
    match /organisations/{orgId} {
      // Any authenticated user can 'get' an org (needed for invite verification)
      allow get: if request.auth != null;
      // Listing orgs is restricted to members
      allow list: if request.auth != null && getUserOrgId() == orgId;
      
      // Admin/HR can write OR user is creating their first org (no orgId yet)
      allow write: if (isAdminOrHR() && getUserOrgId() == orgId) || (request.auth != null && getUserOrgId() == null);
      
      // Roles - read by all org members, write by admin/HR
      match /roles/{roleId} {
        allow read: if request.auth != null && getUserOrgId() == orgId;
        allow write, delete: if isAdmin() && getUserOrgId() == orgId;
      }
      
      // Subcollections
      match /employees/{empId} {
        // Admins/HR: full CRUD including delete
        allow read, write, delete: if isAdminOrHR() && getUserOrgId() == orgId;
        // Employees: read-only
        allow read: if isEmployee() && getUserOrgId() == orgId;
      }
      
      match /shifts/{shiftId} {
        allow read: if request.auth != null && getUserOrgId() == orgId;
        allow write: if isAdminOrHR() && getUserOrgId() == orgId;
      }
      
      match /attendance/{attId} {
        // Admins/HR: full CRUD
        allow read, write: if isAdminOrHR() && getUserOrgId() == orgId;
        // Employees: read own, write own only
        allow read: if isEmployee() && getUserOrgId() == orgId;
        allow write: if isEmployee() && getUserOrgId() == orgId && 
                     resource.data.employeeId == request.auth.uid;
      }
      
      match /corrections/{corrId} {
        allow read: if request.auth != null && getUserOrgId() == orgId;
        allow create: if isEmployee() && getUserOrgId() == orgId;
        allow update: if isAdminOrHR() && getUserOrgId() == orgId;
        allow delete: if isAdmin() && getUserOrgId() == orgId;
      }
      
      match /otApprovals/{approvalId} {
        allow read: if request.auth != null && getUserOrgId() == orgId;
        allow create: if request.auth != null && getUserOrgId() == orgId;
        allow update: if isAdminOrHR() && getUserOrgId() == orgId;
        allow delete: if isAdmin() && getUserOrgId() == orgId;
      }
      
      match /otRequests/{requestId} {
        allow read: if request.auth != null && getUserOrgId() == orgId;
        allow create: if isEmployee() && getUserOrgId() == orgId;
        allow update: if isAdminOrHR() && getUserOrgId() == orgId;
        allow delete: if isAdmin() && getUserOrgId() == orgId;
      }
      
      match /advances/{advanceId} {
        allow read: if request.auth != null && getUserOrgId() == orgId;
        allow create: if (isEmployee() || isAdminOrHR()) && getUserOrgId() == orgId;
        allow update: if isAdminOrHR() && getUserOrgId() == orgId;
        allow delete: if isAdmin() && getUserOrgId() == orgId;
      }
      
      match /salaryIncrements/{incrementId} {
        allow read: if request.auth != null && getUserOrgId() == orgId;
        allow create, update: if isAdminOrHR() && getUserOrgId() == orgId;
      }
      
      match /salarySlips/{slipId} {
        allow read: if request.auth != null && getUserOrgId() == orgId;
        allow create, update: if isAdminOrHR() && getUserOrgId() == orgId;
      }
      
      match /leaves/{leaveId} {
        allow read: if request.auth != null && getUserOrgId() == orgId;
        allow create: if isEmployee() && getUserOrgId() == orgId;
        allow update: if isAdminOrHR() && getUserOrgId() == orgId;
        allow delete: if isAdmin() && getUserOrgId() == orgId;
      }
      
      match /fines/{fineId} {
        allow read: if request.auth != null && getUserOrgId() == orgId;
        allow create: if isEmployee() && getUserOrgId() == orgId;
        allow update: if isAdminOrHR() && getUserOrgId() == orgId;
        allow delete: if isAdmin() && getUserOrgId() == orgId;
      }
      
      match /engagement/{postId} {
        allow read: if request.auth != null && getUserOrgId() == orgId;
        allow create: if isAdminOrHR() && getUserOrgId() == orgId;
        allow update, delete: if isAdmin() && getUserOrgId() == orgId;
      }
      
      match /advances_expenses/{expenseId} {
        allow read: if request.auth != null && getUserOrgId() == orgId;
        allow create: if isEmployee() && getUserOrgId() == orgId;
        allow update: if isAdminOrHR() && getUserOrgId() == orgId;
        allow delete: if isAdmin() && getUserOrgId() == orgId;
      }
      
      match /requests/{requestId} {
        allow read: if request.auth != null && getUserOrgId() == orgId;
        allow create: if isEmployee() && getUserOrgId() == orgId;
        allow update: if isAdminOrHR() && getUserOrgId() == orgId;
        allow delete: if isAdmin() && getUserOrgId() == orgId;
      }
      
      match /activityLogs/{logId} {
        allow read: if request.auth != null && getUserOrgId() == orgId;
      }
      
      match /logs/{logId} {
        allow read: if request.auth != null && getUserOrgId() == orgId;
        allow create: if request.auth != null && getUserOrgId() == orgId;
      }
      
      // RBAC Collections
      match /modules/{moduleId} {
        allow read: if request.auth != null && getUserOrgId() == orgId;
        allow write: if isAdmin() && getUserOrgId() == orgId;
      }
      
      match /role_users/{ruId} {
        allow read: if request.auth != null && getUserOrgId() == orgId;
        allow write: if isAdmin() && getUserOrgId() == orgId;
      }
    }
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
