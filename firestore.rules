[truncated]
all member of that organization.
      // We open GET access to all authenticated users to facilitate join-code validation
      // before a user officially has an 'orgId'. This is a necessary security trade-off
      // for the join-by-code feature.
      allow get: if request.auth != null;
      
      // Restrict updates/deletes/listing to verified members
      allow update, delete, list: if isOrgMember(orgId);
      
      // --- Subcollection Rules ---

      // Employees
      match /employees/{empId} {
        allow read: if isOrgMember(orgId);
        allow create: if isOrgMember(orgId);
        allow update, delete: if isOrgMember(orgId);
      }

      // Shifts
      match /shifts/{shiftId} {
        allow read: if isOrgMember(orgId);
        allow create, update, delete: if isOrgMember(orgId);
      }

      // Attendance  
      match /attendance/{attId} {
        allow read: if isOrgMember(orgId);
        allow create, update, delete: if isOrgMember(orgId);
      }

      // Corrections
      match /corrections/{corrId} {
        allow read: if isOrgMember(orgId);
        allow create: if isOrgMember(orgId);
        allow update, delete: if isOrgMember(orgId);
      }

      // Leaves
      match /leaves/{leaveId} {
        allow read: if isOrgMember(orgId);
        allow create: if isOrgMember(orgId);
        allow update, delete: if isOrgMember(orgId);
      }

      // Salary Slips
      match /salarySlips/{slipId} {
        allow read: if isOrgMember(orgId);
        allow create, update, delete: if isOrgMember(orgId);
      }

      // Advances
      match /advances/{advanceId} {
        allow read: if isOrgMember(orgId);
        allow create: if isOrgMember(orgId);
        allow update, delete: if isOrgMember(orgId);
      }

      // Requests
      match /requests/{reqId} {
        allow read: if isOrgMember(orgId);
        allow create: if isOrgMember(orgId);
        allow update, delete: if isOrgMember(orgId);
      }

      // Roles
      match /roles/{roleId} {
        allow read: if isOrgMember(orgId);
        allow write: if isOrgMember(orgId);
      }

      // Logs
      match /logs/{logId} {
        allow read: if isOrgMember(orgId);
        allow create: if isOrgMember(orgId);
      }

      // Activity Logs
      match /activityLogs/{logId} {
        allow read: if isOrgMember(orgId);
        allow create: if isOrgMember(orgId);
      }

      // Documents
      match /documents/{docId} {
        allow read: if isOrgMember(orgId);
        allow create, update, delete: if isOrgMember(orgId);
      }

      // Recruitment (Jobs, Applicants)
      match /jobs/{jobId} {
        allow read: if isOrgMember(orgId);
        allow create, update, delete: if isOrgMember(orgId);
      }

      match /applicants/{appId} {
        allow read: if isOrgMember(orgId);
        allow create, update, delete: if isOrgMember(orgId);
      }

      // Finances (Fines, Expenses)
      match /fines/{fineId} {
        allow read: if isOrgMember(orgId);
        allow create: if isOrgMember(orgId);
        allow update, delete: if isOrgMember(orgId);
      }

      match /advances_expenses/{expId} {
        allow read: if isOrgMember(orgId);
        allow create: if isOrgMember(orgId);
        allow update, delete: if isOrgMember(orgId);
      }

      // Engagement
      match /engagement/{engId} {
        allow read: if isOrgMember(orgId);
        allow create, update, delete: if isOrgMember(orgId);
      }
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
